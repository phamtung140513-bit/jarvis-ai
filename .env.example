# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF_your_bot_token
# Chủ bot (admin) — bắt buộc
OWNER_TELEGRAM_IDS=123456789
# (tuỳ chọn, tương thích cũ)
ALLOWED_TELEGRAM_IDS=123456789

# ===== Bán hàng / white-label =====
APP_NAME=Jarvis-AI
PRODUCT_TAGLINE=Trợ lý AI coding trên Telegram
SUPPORT_CONTACT=@your_support
PAYMENT_INFO=Chuyen khoan ... roi nhan ma /activate
CURRENCY=VND
PUBLIC_BUY_ENABLED=true

# QR ngan hang (VietQR) — dien de bot gui QR khi /buy (fallback)
BANK_ID=mb
BANK_ACCOUNT=0123456789
BANK_ACCOUNT_NAME=NGUYEN VAN A
BANK_TRANSFER_CONTENT=AI JARVIS
# PAYMENT_QR_PATH=./assets/qr-bank.png

# ===== vietqr-pay (khuyến nghị) =====
# Chạy: cd C:\Users\Admin\vietqr-pay && npm start
VIETQR_PAY_URL=http://127.0.0.1:3000
PAYMENT_WEBHOOK_ENABLED=true
PAYMENT_WEBHOOK_HOST=127.0.0.1
PAYMENT_WEBHOOK_PORT=8787
# Trùng JARVIS_FULFILL_SECRET trong vietqr-pay/.env
PAYMENT_WEBHOOK_SECRET=jarvis-local-webhook-secret-change-me

# License khi bán SOURCE (tuỳ chọn)
REQUIRE_SOFTWARE_LICENSE=false
LICENSE_SECRET=
SOFTWARE_LICENSE_KEY=

# ===== AI provider =====
# groq (free) | openrouter | xai | ollama
AI_PROVIDER=groq
AI_API_KEY=
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=4096

# App
LOG_LEVEL=INFO
DATABASE_URL=sqlite+aiosqlite:///./cache/jarvis.db
WORKSPACE_DIR=./workspace
MAX_HISTORY_MESSAGES=40

# ===== Web chat (python -m webapp.server) =====
WEB_HOST=0.0.0.0
WEB_PORT=7860
# Để trống = ai cũng chat được local. Đặt token nếu public internet.
# WEB_ACCESS_TOKEN=
